
<div id="stockedit-popup" class="white-popup panel panel-default">
	<style>
		#stockedit-popup .form-group {
			margin-left: unset;
			margin-right: unset;
		}
	</style>
	
	<div class="panel-heading">
		<h3 class="panel-title"><i class="fa {{ button_stock_edit_icon }}"></i>&nbsp;{{ button_stock_edit }}<h3>
	</div>
	<div class="panel-body">
		<form action="{{action}}" method="post" enctype="multipart/form-data" id="form-stockedit" class="form-horizontal">
			<input type="hidden" name="id" value="{{ id }}"/>
			<input type="hidden" name="rev" value="{{ rev }}"/>
			<input type="hidden" name="action" value="edit"/>
			<input type="hidden" name="oldlocation" value="{{oldloc}}"/>
			<input type="hidden" name="oldref" value="{{oldref}}"/>
			<div class="form-group">
				<div class="form-group">
					<label class="col-sm-2 control-label" for="input-edit-location">{{ entry_location }}</label>
					<div class="col-sm-10">
						{% for loc in stockLocations %}
							{% if(loc.id == oldloc) %}
								<input type="text"value="{{loc.name}}" class="form-control" disabled />
							{% endif %}
						{% endfor %}
					</div>
				</div>
				<div class="form-group">
					<label class="col-sm-2 control-label" for="input-edit-oldref">{{ entry_fromref }}</label>
					<div class="col-sm-10">
						<input type="text" value="{{oldref}}" class="form-control" disabled />
					</div>
				</div>
				<div class="form-group">
					<label class="col-sm-2 control-label" for="input-edit-oldref">{{ entry_fromqty }}</label>
					<div class="col-sm-10">
						<input type="text" value="{{oldqty}}" class="form-control" disabled />
					</div>
				</div>
			</div>
			<div class="form-group">
				<label class="col-sm-2 control-label" for="input-edit-qty">{{ entry_qty }}</label>
				<div class="col-sm-10">
					<input type="number" id='input-edit-qty' name="qty" min=1 value="{{oldqty}}" class="form-control"/>
				</div>
			</div>
			<input type="submit" data-toggle="tooltip" title="<i class='fa {{ button_stock_edit_icon }}'></i>&nbsp;{{ button_stock_edit }}" class="btn btn-primary"></input>
		</form>
	</div>
</div>
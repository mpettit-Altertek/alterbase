
<div id="stockmove-popup" class="white-popup panel panel-default">
	<style>
		#stockmove-popup .form-group {
			margin-left: unset;
			margin-right: unset;
		}
	</style>
	
	<div class="panel-heading">
		<h3 class="panel-title"><i class="fa {{ button_stock_move_icon }}"></i>&nbsp;{{ button_stock_move }}<h3>
	</div>
	<div class="panel-body">
		<form action="{{action}}" method="post" enctype="multipart/form-data" id="form-stockmove" class="form-horizontal">
			<input type="hidden" name="id" value="{{ id }}"/>
			<input type="hidden" name="rev" value="{{ rev }}"/>
			<input type="hidden" name="action" value="move"/>
			<input type="hidden" name="oldlocation" value="{{oldloc}}"/>
			<input type="hidden" name="oldref" value="{{oldref}}"/>
			<div class="form-group">
				<div class="form-group">
					<label class="col-sm-2 control-label" for="input-move-oldlocation">{{ entry_fromlocation }}</label>
					<div class="col-sm-10">
						{% for loc in stockLocations %}
							{% if(loc.id == oldloc) %}
								<input type="text"value="{{loc.name}}" class="form-control" disabled />
							{% endif %}
						{% endfor %}
						
					</div>
				</div>
				<div class="form-group">
					<label class="col-sm-2 control-label" for="input-move-oldref">{{ entry_fromref }}</label>
					<div class="col-sm-10">
						<input type="text" value="{{oldref}}" class="form-control" disabled />
						
					</div>
				</div>
				<div class="form-group">
					<label class="col-sm-2 control-label" for="input-move-oldref">{{ entry_fromqty }}</label>
					<div class="col-sm-10">
						<input type="text" value="{{oldqty}}" class="form-control" disabled />
					</div>
				</div>
			</div>
			
			<div class="form-group">
				<div class="form-group">
					<label class="col-sm-2 control-label" for="input-move-newlocation">{{ entry_tolocation }}</label>
					<div class="col-sm-10">
						<select id='input-move-newlocation' name="newlocation" value="" class="form-control">
							{% for loc in stockLocations %}
								<option value="{{loc.id}}">{{loc.name}}</option>
							{% endfor %}
						</select>
					</div>
				</div>
				<div class="form-group">
					<label class="col-sm-2 control-label" for="input-move-newref" id="label-move-newref">{{ entry_toref }}</label>
					<div class="col-sm-10">
						<input type="number" id='input-move-newref' name="newref" value="{{oldref}}" class="form-control"/>
					</div>
				</div>
			</div>
			<div class="form-group">
				<label class="col-sm-2 control-label" for="input-move-qty">{{ entry_qty }}</label>
				<div class="col-sm-10">
					<input type="number" id='input-move-qty' name="qty" min=1 value=1 class="form-control"/>
				</div>
			</div>
			<input type="submit" data-toggle="tooltip" title="<i class='fa {{ button_stock_move_icon }}'></i>&nbsp;{{ button_stock_move }}" class="btn btn-primary"></input>
		</form>
	</div>
	<script>
		(function($) {
			console.log("running script from ajax");
			$("#input-move-newlocation").change(function(){
				$(this).find("option:selected").each(function(){
					var optionValue = $(this).attr("value");
					switch(optionValue){
						{% for loc in stockLocations %}
							case "{{loc.id}}":
								$("#label-move-newref").html("{{loc.ref_name}}");
								break;
						{% endfor %}
					}
				});
			}).change();
		})(jQuery);
	</script>
</div>
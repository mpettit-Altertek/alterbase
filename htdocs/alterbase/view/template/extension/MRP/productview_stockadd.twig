
<div id="stockadd-popup" class="white-popup panel panel-default">
	<div class="panel-heading">
		<h3 class="panel-title"><i class="fa {{ button_stock_add_icon }}"></i>&nbsp;{{ button_stock_add }}<h3>
	</div>
	<div class="panel-body">
		<form action="{{ action_stock }}" method="post" enctype="multipart/form-data" id="form-stockadd" class="form-horizontal">
			<input type="hidden" name="id" value="{{ id }}"/>
			<input type="hidden" name="rev" value="{{ rev }}"/>
			<input type="hidden" name="action" value="add"/>
			<div class="form-group">
				<label class="col-sm-2 control-label" for="input-add-newlocation">{{ entry_location }}</label>
				<div class="col-sm-10">
					<select id='input-add-newlocation' name="newlocation" value="" class="form-control">
						{% for loc in stockLocations %}
							<option value="{{loc.id}}">{{loc.name}}</option>
						{% endfor %}
					</select>
				</div>
			</div>
			<div class="form-group">
				<label class="col-sm-2 control-label" id="label-add-newref" for="input-add-newref">{{stockLocations[0].ref_name}}</label>
				<div class="col-sm-10">
					<input type="number" id='input-add-newref' name="newref" value="" class="form-control" required />
				</div>
			</div>
			<div class="form-group">
				<label class="col-sm-2 control-label" for="input-add-qty">{{ entry_qty }}</label>
				<div class="col-sm-10"> 
					<input type="number" id='input-add-qty' name="qty" value="" class="form-control" required />
				</div>
			</div>
			<input type="submit" data-toggle="tooltip" title="<i class='fa {{ button_stock_add_icon }}'></i>&nbsp;{{ button_stock_add }}" class="btn btn-primary"></input>
		</form>
	</div>
	<script>
		(function($) {
			console.log("running script from ajax");
			$("#input-add-newlocation").change(function(){
				$(this).find("option:selected").each(function(){
					var optionValue = $(this).attr("value");
					switch(optionValue){
						{% for loc in stockLocations %}
							case "{{loc.id}}":
								$("#label-add-newref").html("{{loc.ref_name}}");
								break;
						{% endfor %}
					}
				});
			}).change();
		})(jQuery);
	</script>
</div>
{{ header }}{{ column_left }}

<div id="content">
	<style>
		.white-popup {
			position: relative;
			background: #FFF;
			width: auto;
			max-width: 90%;
			margin: 20px auto;
		}
		.white-popup .panel-heading {
			color: #000000;
			border-color: #dcdcdc;
			background: #bfbfbf;
			text-shadow: 0 -1px 0 rgba(50,50,50,0);
		}
	</style>
	<div class="page-header">
		<div class="container-fluid">
			<h1><i class="fa {{ heading_icon }}"></i>&nbsp;{{ heading_title }}</h1><br>
			<ul class="breadcrumb">
				{% for breadcrumb in breadcrumbs %}
				<li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
				{% endfor %}
			</ul>
		</div>
	</div>
	<div class="container-fluid">
		<div class="panel panel-default">
			<div class="panel-heading">
				<h3 class="panel-title">{{ text_report }}<h3>
			</div>
			<div class="panel-body">
				<form action="#" method="post" enctype="multipart/form-data" id="settings" class="form-horizontal">
					<div class="form-group form-inline">
						<label class="col-sm-2 control-label" for="input-root">{{ entry_root }}</label>
						<div class="col-sm-10 ">
							<input type="text" name="root" value="" id="input-root" class="form-control partnumber" size="10"/>
							<select name="rootrev" id="input-rootrev" class="form-control" style="display:inline-block;    width: 160;">
							</select>
							<div id="input-root_name"	class="form-control"	disabled></div>
						</div>
					</div>
					<div class="form-group">
						<label class="col-sm-2 control-label" for="input-rootqty">{{ entry_qty }}</label>
						<div class="col-sm-10">
							<input type="number" name="rootqty" min=1 value="1" id="input-rootqty" class="form-control" disabled/>
						</div>
					</div>
					<div class="form-group">
						<label class="col-sm-2 control-label" for="input-levels">&nbsp;</label>
						<div class="col-sm-10">
							<button id="btnSubmit" disabled type="submit" title="{{ button_generate }}" class="btn btn-primary"><i class="fas fa-hammer"></i>&nbsp;{{ button_generate }}</button>
							<img id="loading" style="display:none;" src="view/image/ajax-loader.gif" />
						</div>
					</div>
				</form>
			</div>
		</div>
	</div>
</div>
<script>
	$(function () {
		function partselected(id,rev){
			$("#input-rootqty").attr("disabled", false);
			$("#btnSubmit").attr("disabled", false);
		}
		$('#input-rootrev').change(function (e) {
			partselected($("#input-root").val(),$("#input-rootrev").val());
		});
		$(".partnumber" ).autocomplete({
			source: decodeURIComponent("{{searchproducturl}}"),
			minLength: 2,
			autoFocus: true,
			select: function(event,ui){
				console.log(ui);
				$("#input-root_name").html(ui.item.name);
				var rev = $("#input-rootrev");
				rev.empty();
				$.each(ui.item.revs,function(k,v){
					rev.append($('<option>', {
						value: v,
						text: v
					}));
				});
				partselected(ui.item.value,$("#input-rootrev").val());
			}
		});
		
		$('form input').keydown(function (e) {
			if (e.keyCode == 13) {
				e.preventDefault();
				return false;
			}
		});
		$( "#settings" ).submit(function( event ) {
			event.preventDefault();
			console.log( $(this).serialize() );
			var formdata = $(this).serialize();
			$.ajax({
				type: "POST",
				url: "{{ajax_route}}",
				data: formdata,
				beforeSend: function () { // Before we send the request, remove the .hidden class from the spinner and default to inline-block.
					$('#loading').show();
					$('#btnSubmit').hide();
				},
				success: function(msg) {
					$('#loading').hide();
					$('#btnSubmit').show();
					$.magnificPopup.open({
						closeOnBgClick: false,
						items: {
							src: msg,
							type: 'inline'
						}
					});
				},
				error: function() {
					$('#loading').hide();
					$('#btnSubmit').show();
					$.magnificPopup.open({
						closeOnBgClick: false,
						items: {
							src: '<div class="white-popup">failure</div>',
							type: 'inline'
						}
					});
				}
			});      
		});
	});
</script>
{{ footer }}
